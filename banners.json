{
  "$schema": {
    "_description": "Banner schedule per game. Update once per patch. All dates are UTC calendar dates (YYYY-MM-DD). The app appends a per-game maintenance-end time: GI = T05:00:00Z (midnight UTC-5, 7-hour window); HSR = T03:00:00Z (10 PM UTC-5, 5-hour window); ZZZ = T03:00:00Z (same as HSR). Confirmed from Game8 maintenance schedule pages.",
    "_fields": {
      "character": "Exact character name as it appears in builds.json (case-sensitive)",
      "phase": "1 or 2 — which half of the patch this banner runs in",
      "start": "ISO date YYYY-MM-DD when the banner opens",
      "end": "ISO date YYYY-MM-DD when the banner closes (exclusive)",
      "rerun": "true if this character has appeared on a banner before",
      "verdict": "Short editorial guidance — 'Pull if X' / 'Skip' / 'High value'. Plain text, no HTML.",
      "patch": "Optional. Patch number string (e.g. '6.6') this banner belongs to."
    },
    "_wiki_sources": {
      "gi": "https://game8.co/games/Genshin-Impact/archives/305012",
      "hsr": "https://game8.co/games/Honkai-Star-Rail/archives/585934",
      "zzz": "https://game8.co/games/Zenless-Zone-Zero/archives/590340"
    },
    "_scrape_hints": [
      "Game8 banner schedule pages list Phase 1 and Phase 2 with explicit dates in wikitables.",
      "GI: game8.co/games/Genshin-Impact/archives/305012 (Current and Next Banner Schedule)",
      "HSR: game8.co/games/Honkai-Star-Rail/archives/NNNNNN (current version banners page)",
      "ZZZ: game8.co/games/Zenless-Zone-Zero/archives/NNNNNN (current version release date page)"
    ]
  },
